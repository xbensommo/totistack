rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserDoc() {
      return get(userDocPath());
    }

    function hasCurrentUserProfile() {
      return signedIn() && exists(userDocPath());
    }

    function isCurrentAccessToken() {
      return hasCurrentUserProfile()
        && request.auth.token.status == 'active'
        && currentUserDoc().data.status == 'active'
        && request.auth.token.accessVersion == currentUserDoc().data.accessVersion;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasPermission(permission) {
      return isCurrentAccessToken()
        && request.auth.token.permissions != null
        && permission in request.auth.token.permissions
        && !(request.auth.token.deniedPermissionKeys != null && permission in request.auth.token.deniedPermissionKeys);
    }

    function ownProfileFields() {
      return [
        'displayName',
        'firstName',
        'lastName',
        'phoneNumber',
        'photoURL',
        'termsAcceptedAt',
        'updatedAt'
      ];
    }

    function accessFields() {
      return [
        'role',
        'roles',
        'permissions',
        'permissionKeys',
        'directPermissionKeys',
        'deniedPermissionKeys',
        'accessVersion',
        'lastAccessChangedAt',
        'lastAccessChangedBy',
        'lastAccessReviewAt',
        'accessReviewedBy',
        'status',
        'emailVerified',
        'mfaEnrolled',
        'mfaRequired',
        'riskLevel',
        'lockedUntil',
        'employeeCode',
        'department',
        'jobTitle',
        'managerUid',
        'isAvailableForAssignments',
        'commissionProfileId',
        'inviteId',
        'suspendedAt',
        'suspendedBy',
        'suspensionReason',
        'restoredAt',
        'restoredBy',
        'deactivatedAt',
        'deactivatedBy',
        'sessionsRevokedAt',
        'sessionsRevokedBy',
        'lastLoginAt',
        'lastPasswordChangeAt',
        'joinedAt',
        'archivedAt',
        'claimsSyncedAt',
        'claimsSchemaVersion',
        'claimsAccessVersion',
        'securityMetadata',
        'createdAt',
        'isDeleted'
      ];
    }

    function onlyOwnProfileFieldsAffected() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownProfileFields());
    }

    function noAccessFieldsAffected() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(accessFields()) == false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || hasPermission('auth.users.view');
      allow create: if false;
      allow update: if isSelf(uid)
        && isCurrentAccessToken()
        && onlyOwnProfileFieldsAffected()
        && noAccessFieldsAffected();
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow read: if hasPermission('auth.roles.view');
      allow create, update, delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if isCurrentAccessToken()
        && (resource.data.userId == request.auth.uid || hasPermission('auth.sessions.view'));
      allow create, update, delete: if false;
    }

    match /user_invites/{inviteId} {
      allow read: if hasPermission('auth.invites.view');
      allow create, update, delete: if false;
    }

    match /password_reset_tokens/{tokenId} {
      allow read, create, update, delete: if false;
    }

    match /access_reviews/{reviewId} {
      allow read: if hasPermission('auth.accessReviews.view');
      allow create, update, delete: if false;
    }

    match /security_policies/{policyId} {
      allow read: if hasPermission('auth.securityPolicy.view');
      allow create, update, delete: if false;
    }

    match /auditLogs/{auditLogId} {
      allow read: if hasPermission('audit.view');
      allow create, update, delete: if false;
    }

    match /entityActivity/{activityId} {
      allow read: if hasPermission('audit.view');
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
